{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u8bbf\u95ee\u6211\u7684\u4e2a\u4eba\u535a\u5ba2","text":"<p>\u7531\u4e8e\u8fd9\u4e2a\u535a\u5ba2\u521a\u5efa\uff0c\u6211\u4e5f\u6ca1\u5b66\u8fc7\u5565\u524d\u7aef\u77e5\u8bc6\uff0c\u6240\u4ee5\u9996\u9875\u4f18\u5316\u8fd8\u662f\u7b49\u6211\u6709\u7a7a\u518d\u8bf4\u5427\u2026\u2026</p> <p>\u8fd9\u4e2a\u535a\u5ba2\u5927\u6982\u4f1a\u5305\u542b\u5982\u4e0b\u7684\u5185\u5bb9\uff1a</p>"},{"location":"#_2","title":"\u5b9e\u4e60\u7b14\u8bb0","text":"<p>\u8bb0\u5f55\u4e00\u4e9b\u9762\u7ecf\uff0c\u540c\u65f6\u4e5f\u8c08\u4e00\u4e9b\u5b9e\u4e60\u7684\u5fc3\u5f97\u4e0e\u6536\u83b7\u3002</p>"},{"location":"#_3","title":"\u9879\u76ee\u7b14\u8bb0","text":"<p>\u8bb0\u5f55\u505a\u9879\u76ee\u7684\u601d\u8def\u4e0e\u8bb0\u5fc6\u3002</p>"},{"location":"#_4","title":"\u6570\u5b66\u4e0e\u8bfe\u7a0b\u7b14\u8bb0","text":"<p>\u6211\u8fd8\u662f\u89c9\u5f97\u65e0\u8bba\u505a\u4efb\u4f55\u4e8b\u6570\u7406\u57fa\u7840\u90fd\u662f\u76f8\u5f53\u91cd\u8981\u7684\u4e00\u73af\u3002\u56e0\u6b64\u8fd9\u4e2a\u5730\u65b9\u4e3b\u8981\u8bb0\u5f55\u6570\u5b66\u548c\u7269\u7406\u7684\u7b14\u8bb0\u3002</p>"},{"location":"#_5","title":"\u7b97\u6cd5\u7b14\u8bb0","text":"<p>\u505a\u5b8c\u4e00\u7c7b\u7b97\u6cd5\u5c31\u8981\u603b\u7ed3\u4e00\u7c7b\uff0c\u8fd9\u4e2a\u90e8\u5206\u5c31\u662f\u4e3a\u4e86\u603b\u7ed3\u7684\u3002</p>"},{"location":"algorithm/Operation_Researsh/","title":"\u7b97\u6cd5\u4e5f\u662f\u89e3\u51b3\u95ee\u9898\u7684\u65b9\u6cd5\uff0c\u8fd0\u7b79\u5b66\u4e5f\u662f\u89e3\u51b3\u95ee\u9898\u7684\u65b9\u6cd5\uff01","text":"<p>\u597d\u4e86\uff0c\u4e3b\u8981\u4e0a\u4e86\u4e00\u4e2a\u8fd0\u7b79\u5b66\u7684\u4e13\u4e1a\u8bfe\uff0c\u611f\u89c9\u662f\u8fd9\u4e13\u4e1a\u96be\u5f97\u5b66\u5230\u7684\u6709\u7528\u7684\u77e5\u8bc6\u3002 \u9042\u7eb3\u5165\u535a\u5ba2\uff01</p>"},{"location":"algorithm/Operation_Researsh/#_2","title":"\u660e\u786e\u8fd0\u7b79\u5b66\u95ee\u9898\u7684\u4e09\u5927\u6838\u5fc3\u89c2\u70b9","text":""},{"location":"algorithm/hashtable/","title":"\u8fd9\u4e2a\u7b14\u8bb0\u5173\u6ce8\u54c8\u5e0c\u8868\u5728\u7b97\u6cd5\u4e2d\u7684\u5e94\u7528","text":""},{"location":"project/git/","title":"\u8fd9\u91cc\u4f5c\u4e3a\u7b14\u8bb0\u8bb0\u5f55\u4e00\u4e9bgit\u7684\u57fa\u672c\u4f7f\u7528","text":""},{"location":"project/git/#git_1","title":"git\u7684\u521d\u59cb\u5316","text":""},{"location":"project/git/#_1","title":"\u6253\u5f00\u7ec8\u7aef\uff0c\u8fdb\u5165\u9879\u76ee\u6839\u76ee\u5f55\uff1a","text":"<pre><code>cd /path/to/your/project\n</code></pre>"},{"location":"project/git/#git_2","title":"\u521d\u59cb\u5316git\u4ed3\u5e93","text":"<pre><code>git add .\ngit commit -m \"\u521d\u59cb\u5316\u9879\u76ee\"\n</code></pre>"},{"location":"project/git/#github","title":"\u5728github\u521b\u5efa\u4e00\u4e2a\u65b0\u4ed3\u5e93\uff0c\u8fd9\u4e2a\u4e0d\u8d58\u8ff0\u4e86\u3002","text":""},{"location":"project/git/#ssh","title":"\u7ed1\u5b9a\u8fdc\u7a0b\u4ed3\u5e93\u5e76\u63a8\u9001\uff08SSH\uff09","text":"<pre><code>git remote add origin git@github.com:Somer2005/csb.github.io.git\ngit remote -v\n\\#\u8fd9\u91cc\u7684\u540e\u4e00\u884c\u662f\u4e3a\u4e86\u68c0\u67e5\u662f\u5426\u7ed1\u5b9a\u6210\u529f\n\ngit push -u origin main\n\\#\u8fd9\u4e00\u6b65\u5c31\u662f\u4e3a\u4e86\u63a8\u9001\u5230github\u4ed3\u5e93\u4e86\n</code></pre>"},{"location":"project/git/#_2","title":"\u540e\u7eed\u5982\u4f55\u66f4\u65b0\u4ed3\u5e93\uff1f","text":"<pre><code>git add .\ngit commit -m \"\u66f4\u65b0\u8bf4\u660e\"\ngit push\n</code></pre>"},{"location":"project/project1/","title":"\u9879\u76ee1\uff1a\u963f\u91cc\u79fb\u52a8\u63a8\u8350\u5927\u8d5b\u7b14\u8bb0","text":""},{"location":"project/project1/#_1","title":"\u9879\u76ee\u5f00\u59cb\u524d\u7684\u601d\u8003","text":"<p>\u76ee\u524d\u6211\u4e3b\u8981\u60f3\u505a\u7684\u8fd8\u662f\u641c\u5e7f\u63a8\uff0c\u60f3\u8981\u53bb\u641c\u5e7f\u63a8\u78e8\u7ec3\u4e00\u4e0b\u4e1a\u52a1\u80fd\u529b\uff0c\u6240\u4ee5\u5148\u505a\u8fd9\u6837\u7684\u9879\u76ee\u3002\u8fd9\u6b21\u8fd9\u4e2a\u9879\u76ee\u7684\u8d5b\u9898\u662f\u6839\u636e11.18-12.18\u7684\u6570\u636e\uff0c\u9884\u6d4b\u7528\u623712.19\u7684\u884c\u4e3a\uff0c\u5f88\u81ea\u7136\u5f88\u6807\u51c6\u7684\u9884\u6d4b\u884c\u4e3a\u3002</p> <p>\u5bf9\u4e8e\u8fd9\u4e2a\u9879\u76ee\uff0c\u6211\u7684\u60f3\u6cd5\u662f\u8fd9\u6bd5\u7adf\u662f\u6211\u7684\u7b2c\u4e00\u4e2a\u641c\u5e7f\u63a8\u9879\u76ee\uff0c\u4e0a\u624b\u505a\u4e1a\u52a1\u62ff\u540d\u8bcd\u5012\u662f\u5176\u6b21\u4e86\uff0c\u5173\u952e\u662f\u4e0d\u8981\u7740\u6025\uff0c\u6162\u6162\u6765\uff0c\u8981\u628a\u80fd\u5b9e\u73b0\u7684\u63a8\u8350\u7b97\u6cd5\u90fd\u5b9e\u73b0\u4e00\u904d\uff0c\u6253\u7262\u57fa\u7840\u3002</p>"},{"location":"project/project1/#_2","title":"\u8d5b\u9898\u6570\u636e\u7ed3\u6784\u5206\u6790","text":"<p>\u524d\u9762\u5df2\u7ecf\u63a2\u8ba8\u8fc7\u5173\u4e8e\u8d5b\u9898\u4e86\uff0c\u8fd9\u91cc\u7814\u7a76\u4e0b\u5173\u4e8e\u8d5b\u9898\u7684\u6570\u636e\u7ed3\u6784\u3002</p> <p>\u4f7f\u7528\u4ee3\u7801\uff1a ww</p>"},{"location":"project/project1/#baseline","title":"Baseline\u7406\u89e3","text":""},{"location":"project/project1/#_3","title":"\u4e2a\u4eba\u601d\u8def","text":""},{"location":"project/project1/#_4","title":"\u4f7f\u7528\u4f20\u7edf\u7684\u53ec\u56de\u91cd\u6392\u7cbe\u6392\u7c97\u6392","text":""},{"location":"project/project1/#_5","title":"\u4f7f\u7528\u751f\u6210\u5f0f\u7684\u65b9\u6cd5","text":""},{"location":"ysyx/PA0/","title":"PA\u7cfb\u5217","text":"<p>\u8fd9\u4e00\u680f\u4e3b\u8981\u8bb0\u5f55\u505aysyx\u5b9e\u9a8c\u7684\u8fc7\u7a0b\u3002</p>"},{"location":"ysyx/PA0/#pa0","title":"\u8fd9\u4e00\u9875\u8bb0\u5f55PA0","text":"<p>PA0\u505a\u7684\u4e8b\u60c5\u662f\u5fc5\u8981\u7684\u51c6\u5907\uff0c\u9996\u5148\u5b89\u88c5Ubuntu\u7684\u8fc7\u7a0b\u81ea\u7136\u662f\u4e0d\u5fc5\u8bf4\uff0c\u6211\u4eec\u76f4\u63a5\u8fdb\u5165\u4e0b\u4e00\u4e2a\u90e8\u5206\u3002</p>"},{"location":"ysyx/PA0/#_1","title":"\u6b65\u9aa4\u4e00\uff1a\u66f4\u65b0\u8f6f\u4ef6\u6e90","text":"<p>\u9996\u5148\uff0c\u6211\u4eec\u5148\u660e\u786e\u4e00\u4e2a\u6982\u5ff5\uff1a</p> <pre><code>sudo apt install xxx\n</code></pre> <p>\u4e0a\u8ff0\u6307\u4ee4\u662f\u4e00\u6761apt\u5b89\u88c5\u6307\u4ee4\uff0c\u4e5f\u8bb8\u4f60\u5728\u8f93\u5165\u8fd9\u884c\u6307\u4ee4\u7684\u65f6\u5019\uff0c\u5c31\u4f1a\u4ea7\u751f\u7591\u95ee\uff1a\u6211\u4eec\u5e73\u5e38\u4e0d\u662f\u90fd\u8981\u53bb\u5b98\u7f51\u627e\u5b89\u88c5\u5305\u5417\uff1f</p> <p>apt\u7684\u8f6f\u4ef6\u6e90\u8d77\u5230\u7684\u5c31\u662f\u4e00\u4e2a\u6574\u5408\u5b89\u88c5\u5305\u7684\u4f5c\u7528\uff0c\u4f60\u53ea\u9700\u8981\u8f93\u5165xxx\uff0c\u4ed6\u5c31\u80fd\u5b89\u88c5\u540d\u5b57\u53ebxxx\u7684\u6587\u4ef6\u4e86\u3002</p> <p>\u800c\u8f6f\u4ef6\u6e90\uff0c\u4e00\u822c\u5c31\u4f1a\u88ab\u5b58\u50a8\u5728/etc/apt/sources.list\u4e2d\uff0c\u8fd9\u5c31\u662f\u6211\u4eec\u8981\u4f18\u5316\u7684\u5bf9\u8c61\u3002</p> <p>\u6211\u4eec\u66f4\u65b0\u8f6f\u4ef6\u6e90\uff0c\u9632\u6b62\u8fd9\u4e2a\u7cfb\u7edf\u81ea\u5e26\u7684\u8f6f\u4ef6\u6e90\u8fc7\u4e8e\u53e4\u8001\u3002</p> <pre><code>sudo sed -i \"s/archive.ubuntu.com/mirrors.tuna.tsinghua.edu.cn/g\" /etc/apt/sources.list\n</code></pre> <p>\u6211\u4eec\u53ef\u4ee5\u4f7f\u7528</p> <pre><code>cat /etc/apt/sources.list\n</code></pre> <p>\u6765\u68c0\u9a8c\u521a\u624d\u7684\u66f4\u65b0\u662f\u5426work\u3002</p> <p>\u63a5\u4e0b\u6765\u7684\u5b89\u88c5\u5de5\u5177\u90e8\u5206\u6ca1\u6709\u4ec0\u4e48\u597d\u505a\u7b14\u8bb0\u7684\u3002</p>"},{"location":"ysyx/PA0/#_2","title":"\u5b89\u88c5\u4e00\u4e2a\u4e2d\u6587\u8f93\u5165\u6cd5","text":"<p>Ubuntu\u7684\u4e2d\u6587\u8f93\u5165\u6cd5\u8fd8\u662f\u6bd4\u8f83\u597d\u5b89\u88c5\u7684\uff0c\u6b65\u9aa4\u5e76\u4e0d\u591a\uff0c\u9047\u5230\u95ee\u9898\u95eeLLM\u57fa\u672c\u4e5f\u90fd\u80fd\u89e3\u51b3\u3002</p>"},{"location":"ysyx/PA0/#1","title":"1. \u786e\u8ba4\u7cfb\u7edf\u8bed\u8a00\u73af\u5883","text":"<p>\u4e3a\u9632\u6b62\u5019\u9009\u6846\u4e0d\u663e\u793a\u6216\u4e71\u7801\uff0c\u9700\u786e\u4fdd\u7cfb\u7edf\u5df2\u5b89\u88c5\u4e2d\u6587\u8bed\u8a00\u5305\u3002</p> <pre><code>sudo apt update\nsudo apt install -y language-pack-zh-hans\n</code></pre>"},{"location":"ysyx/PA0/#2fcix5","title":"2.\u5b89\u88c5Fcix5\u5f15\u64ce","text":"<p>Fcix5\u662f\u4e00\u79cd\u6bd4\u8f83\u65b0\u7684\u8f93\u5165\u6cd5\u6846\u67b6\uff0c\u53cd\u6b63\u5c31\u7c7b\u4f3cWindows\u7684\u5fae\u8f6f\u62fc\u97f3\u5427\u3002</p> <pre><code>sudo apt install -y fcitx5 \\\n    fcitx5-configtool \\\n    fcitx5-frontend-gtk3 fcitx5-frontend-qt5 \\\n    fcitx5-chinese-addons fcitx5-rime\n</code></pre>"},{"location":"ysyx/PA0/#3","title":"3. \u5207\u6362\u7cfb\u7edf\u8f93\u5165\u6cd5\u6846\u67b6","text":"<p>Ubuntu \u9ed8\u8ba4\u4f7f\u7528 IBus\uff0c\u9700\u901a\u8fc7 <code>im-config</code> \u5c06\u8f93\u5165\u6cd5\u6846\u67b6\u5207\u6362\u4e3a Fcitx5\u3002</p> <ol> <li>\u6267\u884c\u914d\u7f6e\u547d\u4ee4\uff1a     <pre><code>im-config\n</code></pre></li> <li>\u5728\u5f39\u51fa\u7684\u5bf9\u8bdd\u6846\u4e2d\u9009\u62e9 fcitx5 \u5e76\u786e\u8ba4\u3002</li> <li>\u7cfb\u7edf\u6ce8\u9500\uff08Logout\uff09\u5e76\u91cd\u65b0\u767b\u5f55\uff0c\u786e\u4fdd\u73af\u5883\u53d8\u91cf\u751f\u6548\u3002</li> </ol>"},{"location":"ysyx/PA0/#4","title":"4. \u914d\u7f6e\u4e2d\u6587\u8f93\u5165\u6e90","text":"<p>\u767b\u5f55\u540e\u9700\u5728 Fcitx5 \u914d\u7f6e\u754c\u9762\u4e2d\u6dfb\u52a0\u5177\u4f53\u7684\u4e2d\u6587\u8f93\u5165\u65b9\u6848\u3002</p> <ol> <li>\u542f\u52a8\u56fe\u5f62\u5316\u914d\u7f6e\u5de5\u5177\uff1a     <pre><code>fcitx5-configtool\n</code></pre></li> <li>\u64cd\u4f5c\u6d41\u7a0b\uff1a<ul> <li>\u70b9\u51fb\u6dfb\u52a0\u6309\u94ae\uff08<code>+</code>\uff09\u3002</li> <li>\u53d6\u6d88\u52fe\u9009 \u201c\u4ec5\u663e\u793a\u5f53\u524d\u8bed\u8a00\u201d\uff08Only Show Current Language\uff09\u3002</li> <li>\u641c\u7d22\u5e76\u9009\u4e2d Pinyin \u6216 Rime \u8fdb\u884c\u6dfb\u52a0\u3002</li> <li>\u786e\u4fdd\u4e2d\u6587\u8f93\u5165\u6cd5\u4f4d\u4e8e\u53ef\u7528\u5217\u8868\uff08Current Input Method\uff09\u4e2d\u3002</li> </ul> </li> </ol>"},{"location":"ysyx/PA0/#5","title":"5. \u9a8c\u8bc1\u4e0e\u6392\u9519","text":"<ul> <li>\u5207\u6362\u5feb\u6377\u952e\uff1a\u9ed8\u8ba4\u4f7f\u7528 <code>Ctrl + Space</code>\uff08\u53ef\u5728 Global Options -&gt; Trigger Input Method \u4e2d\u4fee\u6539\uff09\u3002</li> <li>\u91cd\u8f7d\u5b88\u62a4\u8fdb\u7a0b\uff1a\u82e5\u72b6\u6001\u680f\u65e0\u56fe\u6807\u6216\u65e0\u6cd5\u5524\u8d77\uff0c\u53ef\u6267\u884c\u4ee5\u4e0b\u547d\u4ee4\u5f3a\u5236\u91cd\u542f\u5e76\u67e5\u770b\u8c03\u8bd5\u65e5\u5fd7\uff1a     <pre><code>fcitx5 -r -d\n</code></pre></li> </ul>"},{"location":"ysyx/PA0/#vim","title":"Vim","text":"<p>Vim\u7684\u5b89\u88c5\u4e5f\u6bd4\u8f83\u7b80\u5355\uff0c\u76f4\u63a5\u4f7f\u7528apt\u5b89\u88c5\u5373\u53ef\u3002</p> <pre><code>sudo apt install vim\n</code></pre> <p>\u4e4b\u540e\u662f\u914d\u7f6evim\uff1a</p> <pre><code>cp /etc/vim/vimrc ~/.vimrc\n</code></pre> <p>cp\u7684\u610f\u601dCPDD\u2026\u2026\u5e76\u975e\u5e76\u975e\uff0ccp\u7684\u610f\u601d\u662fcopy\uff0c\u590d\u5236\u7684\u610f\u601d\u3002</p> <p>\u4e0a\u9762\u8fd9\u884c\u547d\u4ee4\u662f\u628a\u7cfb\u7edf\u81ea\u5e26\u7684vim\u914d\u7f6e\u6587\u4ef6\u590d\u5236\u5230\u7528\u6237\u76ee\u5f55\u4e0b\uff0c\u4f5c\u4e3a\u7528\u6237\u81ea\u5df1\u7684vim\u914d\u7f6e\u6587\u4ef6\u3002</p> <p>\u76f8\u4fe1\u8fd9\u4e2a\u65f6\u5019\u6709\u53d1\u73b0\u529b\u7684\u670b\u53cb\u5c31\u5df2\u7ecf\u611f\u89c9\u5230\u4e86\uff0c\u8fd9\u4e9b\u914d\u7f6e\u6587\u4ef6\uff0c\u597d\u50cf\u90fd\u5728/etc\u76ee\u5f55\u4e0b\u3002</p> <p>\u6211\u771f\u89c9\u5f97\u914d\u7f6evim\u6ca1\u4ec0\u4e48\u53ef\u8bf4\u7684\uff0c\u4e5f\u4e0d\u662fPA0\u7684\u91cd\u70b9\uff0c\u5c31\u8fd9\u6837\u5427\uff0c\u5177\u4f53\u7684\u8be6\u7ec6\u64cd\u4f5c\uff0c\u4f60\u8fdb\u53bb\u770b\u770b\u5c31\u77e5\u9053\u3002</p>"},{"location":"ysyx/PA0/#gcc","title":"gcc\u7f16\u8bd1","text":"<p>gcc\u7684\u5b89\u88c5\u4e5f\u5f88\u7b80\u5355\uff0c\u521a\u624d\u5b89\u88c5\u5fc5\u8981\u5de5\u5177\u7684\u65f6\u5019\uff0c\u6211\u4eec\u5df2\u7ecf\u5b89\u88c5\u8fc7\u3002</p> <p>GDB\u7684\u4f7f\u7528\u548c\u8c03\u8bd5\u5728\u535a\u5ba2\u5b9e\u7528\u5de5\u5177\u4e0b\u9762\u3002</p> <p>tmux\u4e5f\u662f\uff0c\u8fd9\u4e9b\u90fd\u662f\u8bb0\u5728\u5176\u5b83\u90e8\u5206\u7684\uff0c\u8fd9\u91cc\u4e0d\u8bf4\u3002</p>"},{"location":"ysyx/PA0/#pa","title":"\u4e3aPA\u6574\u7406\u5fc5\u8981\u8d44\u6e90","text":"<p>\u8fd9\u4e2a\u5c31\u2026\u2026\u6211\u4e0d\u77e5\u9053\u8fd9\u4e2a\u6709\u4ec0\u4e48\u597d\u8bb0\u5f55\u7684\uff0c\u8fd9\u4e2a\u5c31\u662f\u7eaf\u64cd\u4f5c\u3002</p>"},{"location":"ysyx/PA0/#nemu","title":"\u7f16\u8bd1\u5e76\u8ba9NEMU\u8dd1\u8d77\u6765","text":"<p>PA\u4e00\u5f00\u59cb\u8ba9\u6211\u4eec\u8fdb\u5165/nemu\uff0c\u7136\u540e\uff1a</p> <pre><code>make menuconfig\n</code></pre> <p>\u8fd9\u4e2a\u547d\u4ee4\u4f1a\u8ba9\u6211\u4eec\u8fdb\u5165\u4e00\u4e2a\u914d\u7f6e\u754c\u9762\uff0c\u6211\u4eec\u53ea\u9700\u8981\u628a\u91cc\u9762\u7684\u9009\u9879\u90fd\u8bbe\u7f6e\u6210\u9ed8\u8ba4\u5373\u53ef\u3002</p> <p>\u4f46\u662f\u539f\u8bb2\u4e49\u4e5f\u8bf4\u4e86\uff0c\u76f4\u63a5\u8dd1\u8fd9\u4e2a\u4f1a\u62a5\u9519\u7684\uff0c\u539f\u56e0\u5728\u4e8emenuconfig\u9700\u8981\u4e94\u4e2a\u5305\uff1a</p> <ul> <li>gcc</li> <li>make</li> <li>bison</li> <li>flex</li> <li>ncurses</li> </ul> <p>\u4f46\u662f\u6211\u4eec\u6ca1\u6709\u88c5bison\uff0c\u88c5\u4e00\u4e0b\u95ee\u9898\u5c31\u89e3\u51b3\u3002</p> <p>NEMU</p> <p>NEMU\u662f\u4e00\u4e2a\u6559\u5b66\u7528\u7684\u6a21\u62df\u5668\uff0c\u4e3b\u8981\u7528\u4e8e\u8ba1\u7b97\u673a\u4f53\u7cfb\u7ed3\u6784\u8bfe\u7a0b\u4e2d\uff0c\u5e2e\u52a9\u5b66\u751f\u7406\u89e3\u8ba1\u7b97\u673a\u7cfb\u7edf\u7684\u5de5\u4f5c\u539f\u7406\u3002NEMU\u652f\u6301\u591a\u79cd\u6307\u4ee4\u96c6\u67b6\u6784\uff08ISA\uff09\uff0c\u5982x86\u3001MIPS\u7b49\uff0c\u5141\u8bb8\u7528\u6237\u5728\u6a21\u62df\u73af\u5883\u4e2d\u8fd0\u884c\u548c\u8c03\u8bd5\u7a0b\u5e8f\u3002</p> <p>\u54e6\u6211\u662f\u5c0f\u4e11\u539f\u6765PA1\u4f1a\u8be6\u7ec6\u4ecb\u7ecd\u3002</p> <p>\u5173\u4e8emake\u7684\u4e00\u4e9b\u4ecb\u7ecd</p> <p>make\u662f\u4e00\u4e2a\u81ea\u52a8\u5316\u6784\u5efa\u5de5\u5177\uff0c\u4e3b\u8981\u7528\u4e8e\u7ba1\u7406\u548c\u7ef4\u62a4\u5927\u578b\u9879\u76ee\u7684\u7f16\u8bd1\u8fc7\u7a0b\u3002\u5b83\u901a\u8fc7\u8bfb\u53d6\u540d\u4e3aMakefile\u7684\u6587\u4ef6\u4e2d\u7684\u89c4\u5219\u548c\u4f9d\u8d56\u5173\u7cfb\uff0c\u81ea\u52a8\u5316\u5730\u6267\u884c\u7f16\u8bd1\u3001\u94fe\u63a5\u7b49\u4efb\u52a1\uff0c\u4ece\u800c\u7b80\u5316\u4e86\u8f6f\u4ef6\u5f00\u53d1\u4e2d\u7684\u6784\u5efa\u8fc7\u7a0b\u3002</p> <p>make\u7684\u4e3b\u8981\u529f\u80fd\u5305\u62ec\uff1a</p> <ol> <li>\u81ea\u52a8\u5316\u6784\u5efa\uff1a\u6839\u636eMakefile\u4e2d\u7684\u89c4\u5219\uff0c\u81ea\u52a8\u6267\u884c\u7f16\u8bd1\u548c\u94fe\u63a5\u64cd\u4f5c\uff0c\u51cf\u5c11\u624b\u52a8\u64cd\u4f5c\u7684\u7e41\u7410\u3002</li> <li>\u4f9d\u8d56\u7ba1\u7406\uff1a\u8ddf\u8e2a\u6587\u4ef6\u4e4b\u95f4\u7684\u4f9d\u8d56\u5173\u7cfb\uff0c\u4ec5\u91cd\u65b0\u7f16\u8bd1\u90a3\u4e9b\u81ea\u4e0a\u6b21\u6784\u5efa\u4ee5\u6765\u53d1\u751f\u53d8\u5316\u7684\u6587\u4ef6\uff0c\u63d0\u9ad8\u6784\u5efa\u6548\u7387\u3002</li> <li>\u591a\u5e73\u53f0\u652f\u6301\uff1a\u53ef\u4ee5\u5728\u4e0d\u540c\u7684\u64cd\u4f5c\u7cfb\u7edf\u548c\u73af\u5883\u4e2d\u4f7f\u7528\uff0c\u9002\u5e94\u5404\u79cd\u5f00\u53d1\u9700\u6c42\u3002</li> <li>\u7075\u6d3b\u5b9a\u4e49\u53d8\u91cf\uff1a\u5141\u8bb8\u7528\u6237\u81ea\u5b9a\u4e49\u89c4\u5219\u548c\u53d8\u91cf\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u9879\u76ee\u9700\u6c42\u3002</li> <li>\u5e76\u884c\u6784\u5efa\uff1a\u652f\u6301\u5e76\u884c\u6267\u884c\u4efb\u52a1\uff0c\u5229\u7528\u591a\u6838\u5904\u7406\u5668\u52a0\u5feb\u6784\u5efa\u901f\u5ea6\u3002</li> </ol> <p>\u603b\u4e4b\uff0cmake\u662f\u8f6f\u4ef6\u5f00\u53d1\u4e2d\u4e0d\u53ef\u6216\u7f3a\u7684\u5de5\u5177\uff0c\u6781\u5927\u5730\u7b80\u5316\u4e86\u6784\u5efa\u8fc7\u7a0b\uff0c\u63d0\u9ad8\u4e86\u5f00\u53d1\u6548\u7387\u3002</p> <p>PA\u8bb2\u4e49\u4e2d\u63d0\u5230\u7684make\uff0c\u4f1a\u5728\u5b9e\u7528\u5de5\u5177\u680f\u8be6\u7ec6\u4ecb\u7ecd\u5e76\u6301\u7eed\u66f4\u65b0\u3002</p>"}]}