---
import { Image } from 'astro:assets'

import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import Sponsors from '@/components/projects/Sponsors.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import alipay from '@/assets/alipay-qrcode.jpg'
import KeyIcon from '@/assets/icons/key.svg'
import wechat from '@/assets/wechat-qrcode.jpg'

const headings = [
  { depth: 2, slug: 'programs', text: 'Programs' },
  { depth: 2, slug: 'learnings', text: 'Learnings' },
  { depth: 2, slug: 'others', text: 'Others' },
  { depth: 2, slug: 'gpg-signature', text: 'GPG Signature' },
]
---

<PageLayout title='Projects' {headings} view>

  <h2 id='programs'>AI agent</h2>
  <ProjectSection
    projects={[
      {
        name: 'Arxiv Reading Fast Agent',
        description: '考虑利用OpenClaw重构的一款Arxiv日报Agent,主要是通报arxiv的新前沿发现。',
        links: [
          { type: 'github', href: 'https://github.com/cworld1/astro-theme-pure' },
          { type: 'site', href: 'https://astro-pure.js.org/' },
          { type: 'doc', href: 'https://astro-pure.js.org/docs/list' },
          { type: 'release', href: 'https://www.npmjs.com/package/astro-pure' }
        ]
      },
      {
        name: 'Agent for Data Analysis',
        description: '',
        links: [
          { type: 'github', href: 'https://github.com/zhuozhiyongde/pku-art' },
          { type: 'site', href: 'https://github.com/zhuozhiyongde/pku-art' },
          { type: 'doc', href: 'https://docs.arthals.ink/docs/pku-art' }
        ]
      }
    ]}
  />
  <Collapse title='Some old projects'>
    <ProjectSection
      projects={[
        {
          name: '🧩 rehype-autolink-headings-simple',
          description: 'A simple version of rehype-autolink-headings',
          links: [
            { type: 'github', href: 'https://github.com/cworld1/rehype-autolink-headings-simple' },
            {
              type: 'release',
              href: 'https://www.npmjs.com/package/rehype-autolink-headings-simple'
            }
          ]
        },
        {
          name: 'Gaussian NB',
          description:
            'Simulating the Parsimonious Bayesian Algorithm with Python and Finding the Probability Prediction of Breast Cancer ',
          links: [{ type: 'github', href: 'https://github.com/cworld1/gaussian-nb' }]
        }
      ]}
    />
  </Collapse>

  <h2 id='programs'>Recommend System</h2>
  <ProjectSection
    projects={[
      {
        name: 'MiniOneRec',
        description: '一个基于大模型驱动的推荐系统框架,使用LoRA微调和RLHF微调。',
        links: [
          { type: 'github', href: 'https://github.com/cworld1/astro-theme-pure' },
          { type: 'site', href: 'https://astro-pure.js.org/' },
          { type: 'doc', href: 'https://astro-pure.js.org/docs/list' },
          { type: 'release', href: 'https://www.npmjs.com/package/astro-pure' }
        ]
      },
      {
        name: 'LLM4Rec:Qwen Agent',
        description: '使用小参数模型预训练一个推荐Agent,并尝试投入生产（当然,这并没有很好的效果）。',
        links: [
          { type: 'github', href: 'https://github.com/zhuozhiyongde/pku-art' },
          { type: 'site', href: 'https://github.com/zhuozhiyongde/pku-art' },
          { type: 'doc', href: 'https://docs.arthals.ink/docs/pku-art' }
        ]
      }
    ]}
  />
  <Collapse title='Some old projects'>
    <ProjectSection
      projects={[
        {
          name: '🧩 rehype-autolink-headings-simple',
          description: 'A simple version of rehype-autolink-headings',
          links: [
            { type: 'github', href: 'https://github.com/cworld1/rehype-autolink-headings-simple' },
            {
              type: 'release',
              href: 'https://www.npmjs.com/package/rehype-autolink-headings-simple'
            }
          ]
        },
        {
          name: 'Gaussian NB',
          description:
            'Simulating the Parsimonious Bayesian Algorithm with Python and Finding the Probability Prediction of Breast Cancer ',
          links: [{ type: 'github', href: 'https://github.com/cworld1/gaussian-nb' }]
        }
      ]}
    />
  </Collapse>
  <h2 id='learnings'>Learnings</h2>
  <ProjectSection
    class='my-2'
    projects={[
      {
        name: 'MIT6.006',
        description: 'Some notes and code about learning R language',
        links: [
          { type: 'github', href: 'https://github.com/cworld1/r-learning' },
          { type: 'site', href: 'https://cworld1.github.io/r-learning' }
        ]
      },
      {
        name: '深入理解计算机系统 / CSAPP',
        description: '从程序员视角介绍计算机系统,虽然看上去是一门科普课但实际上每一个地方都层层深入,点击即可看到我的笔记,作业答案和Project。',
        links: [
          {
            type: 'github',
            href: 'https://github.com/zhuozhiyongde/Introduction-To-Computer-System-2023Fall-PKU'
          }
        ]
      },
      {
        name: '一生一芯计划',
        description: '一生一芯计划聚焦RISC-V处理器设计,仓库里存放了我每个阶段的笔记和代码实现。',
        links: [
          { type: 'github', href: 'https://github.com/cworld1/r-learning' },
          { type: 'site', href: 'https://cworld1.github.io/r-learning' }
        ]
      },
      {
        name: 'rCore-清华大学开源操作系统训练营',
        description: '参加开源操作系统训练营的实现,其中包括rust的学习内容与使用Rust从零开始实现的内核',
        links: [
          { type: 'github', href: 'https://github.com/cworld1/r-learning' },
          { type: 'site', href: 'https://cworld1.github.io/r-learning' }
        ]
      },
    ]}
  />



  <h2 id='gpg-signature'>GPG Signature</h2>
  <p>
    You can verify the authenticity of the files I signed by checking the GPG signature. My GPG key
    is <code>114514</code>, and you can find it on the opengpg key servers or download from it.
  </p>
  <Button href='https://keys.openpgp.org/search?q=114514' title='Checkout my key' target='_blank'>
    <KeyIcon class='size-5' slot='before' />
  </Button>

  <h2 id='sponsorship'>Sponsorship</h2>
  <p>Chinese methods: <a href="https://afdian.com/a/cworld" target="_blank">Afadian</a>, Wechat or Alipay </p>
  <Sponsorship
    methods={[
      { name: 'WeChat', icon: 'wechat-pay', image: wechat },
      { name: 'Alipay', icon: 'alipay', image: alipay }
    ]}
  />
  <p>Global methods: <a href="https://ko-fi.com/cworld0" target="_blank">Ko-fi</a> </p>
  <p>Please leave a message or contact me proactively after sponsorship. My email is:
    <code style='cursor: pointer'
      onclick='const m=atob(this.textContent);alert(m);window.open(`mailto:${m}`,"_blank")'
    >Y3dvcmxkMEBxcS5jb20=</code>
    (click code to transform base64).
  </p>
  <p>Thanks to the following sponsors:</p>
</PageLayout>


